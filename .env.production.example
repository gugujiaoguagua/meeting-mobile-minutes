MEETING_STATE_STORE=json
DATABASE_URL=postgres://meeting_loop:meeting_loop_change_me@db:5432/meeting_loop
NEXT_PUBLIC_ENABLE_DEEPSEEK_DRAFT=0

MEETING_PUBLIC_BASE_URL=https://your-domain.example.com
WECOM_AGENT_ID=
WECOM_TOKEN_API_URL=
WECOM_ACCESS_TOKEN=
WECOM_TOKEN_FILE=
WECOM_API_BASE_URL=https://qyapi.weixin.qq.com/cgi-bin
WECOM_SYNC_ROOT_DEPARTMENT_ID=1
WECOM_PRESIDENT_USERID=
WECOM_USERID_FROM_EMP_ID=1

# JSON object. Keys may be internal user id, employeeNo, or name. Values are Enterprise WeChat UserID.
# Prefer file-based map for production. Inline JSON overrides duplicate keys in the file.
WECOM_USER_MAP_JSON=
WECOM_USER_MAP_FILE=config/wecom-user-map.example.json

# Set WECOM_CORP_ID and trusted callback domain in Enterprise WeChat to enable official OAuth auto-login.
WECOM_CORP_ID=
WECOM_OAUTH_STATE_SECRET=

# Enterprise WeChat application message receiving callback.
# Configure URL as https://your-domain.example.com/api/wecom/callback.
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_ENCODING_AES_KEY=
WECOM_CALLBACK_RECEIVE_ID=

# Optional fallback auto-login for testing signed links when OAuth is not configured.
WECOM_DEEPLINK_SECRET=

# Tencent Cloud ASR. Keep real values only in server .env or deployment variables.
TENCENTCLOUD_APPID=
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_REGION=ap-guangzhou
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh
TENCENT_ASR_RES_TEXT_FORMAT=3
TENCENT_ASR_CHANNEL_NUM=1
TENCENT_ASR_POLL_TIMEOUT_MS=45000
TENCENT_ASR_POLL_INTERVAL_MS=2000
TENCENT_ASR_NORMALIZE_AUDIO=1
TENCENT_ASR_AUDIO_FILTER=dynaudnorm=f=150:g=25,volume=12dB,alimiter=limit=0.95
TENCENT_REALTIME_ASR_ENGINE_MODEL_TYPE=16k_zh
TENCENT_REALTIME_ASR_VOICE_FORMAT=1
TENCENT_REALTIME_ASR_NEED_VAD=1
TENCENT_REALTIME_ASR_FILTER_EMPTY_RESULT=1
TENCENT_REALTIME_ASR_MAX_SPEAK_TIME=10000
TENCENT_REALTIME_ASR_SIGNATURE_TTL_SECONDS=300

# Meeting object storage. Keep real AccessKey values only in server .env.
MEETING_OBJECT_STORAGE=
MEETING_OSS_REGION=oss-cn-shanghai
MEETING_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
MEETING_OSS_BUCKET=your-oss-bucket
MEETING_OSS_PREFIX=meeting-loop/prod
MEETING_OSS_ACCESS_KEY_ID=
MEETING_OSS_ACCESS_KEY_SECRET=
MEETING_OSS_SIGNED_URL_TTL_SECONDS=7200
MEETING_OSS_REQUEST_TIMEOUT_MS=300000
MEETING_OSS_MULTIPART_THRESHOLD_BYTES=20971520
MEETING_OSS_MULTIPART_PART_SIZE_BYTES=8388608

# PostgreSQL backup to OSS. The cron installer reads these from the shell,
# while the backup script uses safe defaults when they are unset.
MEETING_DB_BACKUP_OSS_KEY_PREFIX=backups/postgres
MEETING_DB_BACKUP_LOCAL_DIR=.local-data/db-backups/postgres
MEETING_DB_BACKUP_LOCAL_RETENTION_DAYS=2
MEETING_DB_BACKUP_CRON_SCHEDULE=17 3 * * *
MEETING_SERVER_CLEANUP_CRON_SCHEDULE=37 4 * * 0
DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=3
