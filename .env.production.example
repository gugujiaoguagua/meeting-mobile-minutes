MEETING_STATE_STORE=json
DATABASE_URL=postgres://meeting_loop:meeting_loop_change_me@db:5432/meeting_loop
NEXT_PUBLIC_ENABLE_DEEPSEEK_DRAFT=0

MEETING_PUBLIC_BASE_URL=https://your-domain.example.com
WECOM_AGENT_ID=
WECOM_TOKEN_API_URL=
WECOM_ACCESS_TOKEN=
WECOM_TOKEN_FILE=

# JSON object. Keys may be internal user id, employeeNo, or name. Values are Enterprise WeChat UserID.
# Prefer file-based map for production. Inline JSON overrides duplicate keys in the file.
WECOM_USER_MAP_JSON=
WECOM_USER_MAP_FILE=config/wecom-user-map.example.json

# Set WECOM_CORP_ID and trusted callback domain in Enterprise WeChat to enable official OAuth auto-login.
WECOM_CORP_ID=
WECOM_OAUTH_STATE_SECRET=

# Optional fallback auto-login for testing signed links when OAuth is not configured.
WECOM_DEEPLINK_SECRET=
